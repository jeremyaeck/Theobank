generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  balance      Int      @default(0)
  isAdmin      Boolean  @default(false)
  approved     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  duelsAsChallenger Duel[]        @relation("Challenger")
  duelsAsOpponent   Duel[]        @relation("Opponent")
  transactions      Transaction[]
  auctionBids       AuctionBid[]
  auctionWins       AuctionItem[]
  bonusUsages       BonusUsage[]
  teamMembership    TeamMember?
}

model Team {
  id        String       @id @default(cuid())
  name      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  members   TeamMember[]
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String   @unique
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

enum DuelStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

model Duel {
  id             String     @id @default(cuid())
  challengerId   String
  opponentId     String
  betAmount      Int
  status         DuelStatus @default(PENDING)
  challengerVote String?
  opponentVote   String?
  winnerId       String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  challenger   User          @relation("Challenger", fields: [challengerId], references: [id])
  opponent     User          @relation("Opponent", fields: [opponentId], references: [id])
  transactions Transaction[]
}

enum TransactionType {
  INITIAL_BALANCE
  DUEL_LOCK
  DUEL_WIN
  DUEL_REFUND
  ADMIN_CREDIT
  ADMIN_DEBIT
  ADMIN_RESET
  AUCTION_BID
  BONUS_STEAL_GAIN
  BONUS_STEAL_LOSS
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  amount      Int
  type        TransactionType
  description String?
  duelId      String?
  createdAt   DateTime        @default(now())

  user User  @relation(fields: [userId], references: [id])
  duel Duel? @relation(fields: [duelId], references: [id])
}

enum AuctionPhaseStatus {
  LOCKED
  ACTIVE
  FINISHED
}

model AuctionPhase {
  id        String             @id @default(cuid())
  phase     Int                @unique
  status    AuctionPhaseStatus @default(LOCKED)
  startedAt DateTime?
  endsAt    DateTime?
  items     AuctionItem[]
  createdAt DateTime           @default(now())
}

model AuctionItem {
  id          String       @id @default(cuid())
  name        String
  displayName String
  isMystery   Boolean      @default(false)
  phaseId     String
  phase       AuctionPhase @relation(fields: [phaseId], references: [id])
  position    Int
  bids        AuctionBid[]
  winnerId    String?
  winner      User?        @relation(fields: [winnerId], references: [id])
  winningBid  Int?
}

model AuctionBid {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  itemId      String
  item        AuctionItem @relation(fields: [itemId], references: [id])
  amount      Int
  validatedAt DateTime @default(now())

  @@unique([userId, itemId])
}

enum BonusType {
  CLASSEMENT
  SOLDE_MAX
  SOLDE_MOYEN
  GAIN_DOUBLE
  VOL
}

model BonusUsage {
  id             String    @id @default(cuid())
  userId         String
  bonusType      BonusType
  usedAt         DateTime  @default(now())
  expiresAt      DateTime?
  data           Json?
  acknowledgedAt DateTime? // For VOL: when the victim dismissed the alert
  user           User      @relation(fields: [userId], references: [id])
}
